{
  "name": "kinetic-text-3d",
  "version": "0.1.2",
  "description": "3D kinetic typography React component with WebGL shaders, bloom glow, and mouse interaction",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "three": "^0.160.0",
    "gsap": "^3.12.0",
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/three": "^0.160.0",
    "tsup": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "keywords": [
    "react",
    "three",
    "3d",
    "text",
    "kinetic",
    "typography",
    "webgl",
    "bloom",
    "shader"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/odina101/kinetic-text-3d.git"
  },
  "homepage": "https://github.com/odina101/kinetic-text-3d",
  "license": "MIT"
}
